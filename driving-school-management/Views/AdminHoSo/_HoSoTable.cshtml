@model List<driving_school_management.ViewModels.HoSoVM>

<div class="table-responsive">
    <table class="table admin-table align-middle mb-0">
        <thead>
            <tr>
                <th class="text-center stt-col">STT</th>
                <th>Tên học viên</th>
                <th>CCCD</th>
                <th>Tên hồ sơ</th>
                <th>Hạng</th>
                <th>Ngày đăng ký</th>
                <th>Trạng thái</th>
                <th class="text-center action-col">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var stt = 1;

                foreach (var item in Model)
                {
                    var statusClass = item.TrangThai == "Đã duyệt"
                        ? "status-approved"
                        : item.TrangThai == "Từ chối"
                            ? "status-rejected"
                            : "status-processing";

                    <tr>
                        <td class="text-center fw-semibold text-slate">
                            @(stt)
                        </td>
                        <td>
                            <div class="student-name">@item.HoTen</div>
                        </td>
                        <td>
                            <span class="mono-text">@item.CCCD</span>
                        </td>
                        <td>
                            <div class="hoso-name">@item.TenHoSo</div>
                        </td>
                        <td>
                            <span class="hang-badge">@item.Hang</span>
                        </td>
                        <td>
                            <span class="date-text">@item.NgayDangKy.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td>
                            <span class="status-badge @statusClass">@item.TrangThai</span>
                        </td>
                        <td class="text-center">
                            <a asp-controller="AdminHoSo"
                                   asp-action="Details"
                                   asp-route-id="@item.HoSoId"
                                   class="btn btn-view-detail"
                                   title="Xem chi tiết">
                                <i class="fa fa-eye"></i>
                            </a>
                        </td>
                    </tr>

                    stt++;
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center empty-state-cell">
                        <div class="empty-state-wrap">
                            <div class="empty-icon">
                                <i class="fa fa-folder-open"></i>
                            </div>
                            <div class="empty-title">Không có dữ liệu</div>
                            <div class="empty-subtitle">Không tìm thấy hồ sơ phù hợp với bộ lọc hiện tại.</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .admin-table {
        border-collapse: separate;
        border-spacing: 0;
        min-width: 980px;
    }

        .admin-table thead th {
            background: linear-gradient(180deg, #f8fbff 0%, #f1f5f9 100%);
            color: #0f172a;
            font-size: 14px;
            font-weight: 800;
            border-bottom: 1px solid #dbe3ef;
            border-top: 1px solid #e5edf6;
            padding: 15px 14px;
            white-space: nowrap;
        }

            .admin-table thead th:first-child {
                border-top-left-radius: 14px;
            }

            .admin-table thead th:last-child {
                border-top-right-radius: 14px;
            }

        .admin-table tbody td {
            padding: 14px;
            border-bottom: 1px solid #eef2f7;
            vertical-align: middle;
            background: #fff;
        }

        .admin-table tbody tr {
            transition: all .2s ease;
        }

            .admin-table tbody tr:hover td {
                background: #f8fbff;
            }

    .stt-col {
        width: 72px;
    }

    .action-col {
        width: 110px;
    }

    .text-slate {
        color: #334155;
    }

    .student-name {
        font-weight: 700;
        color: #0f172a;
        line-height: 1.4;
    }

    .mono-text {
        font-family: Consolas, monospace;
        font-size: 14px;
        color: #1e293b;
        font-weight: 600;
    }

    .hoso-name {
        color: #0f172a;
        font-weight: 600;
        line-height: 1.45;
        max-width: 360px;
    }

    .hang-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 74px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(37,99,235,0.10);
        color: #2563eb;
        font-weight: 700;
        font-size: 13px;
    }

    .date-text {
        color: #334155;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        white-space: nowrap;
    }

    .status-processing {
        background: rgba(6,182,212,0.14);
        color: #0891b2;
    }

    .status-approved {
        background: rgba(34,197,94,0.14);
        color: #15803d;
    }

    .status-rejected {
        background: rgba(239,68,68,0.14);
        color: #dc2626;
    }

    .btn-view-detail {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 18px rgba(37,99,235,0.20);
        transition: all .2s ease;
        text-decoration: none;
    }

        .btn-view-detail:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
            color: #fff !important;
        }

    .empty-state-cell {
        padding: 42px 20px !important;
        background: #fff !important;
    }

    .empty-state-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: #eff6ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .empty-title {
        font-size: 17px;
        font-weight: 800;
        color: #0f172a;
    }

    .empty-subtitle {
        font-size: 14px;
        color: #64748b;
    }

    @@media (max-width: 991.98px) {
        .admin-table {
            min-width: 900px;
        }
    }
</style>