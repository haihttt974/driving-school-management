@model List<driving_school_management.ViewModels.HoSoVM>

@{
    ViewData["Title"] = "Danh sách hồ sơ thí sinh";
}

<section class="content">
    <div class="container-fluid admin-hoso-page">

        <div class="hoso-hero mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="hero-badge">
                        <i class="fa fa-folder-open"></i>
                        <span>Quản lý hồ sơ</span>
                    </div>
                    <h2 class="hero-title mb-2">Danh sách hồ sơ thí sinh</h2>
                    <div class="hero-subtitle">Theo dõi, tìm kiếm và quản lý hồ sơ theo CCCD, họ tên, hạng GPLX và trạng thái.</div>
                </div>
            </div>
        </div>

        <div class="card hoso-card border-0">
            <div class="card-body p-3 p-lg-4">

                <div class="filter-panel mb-4">
                    <form id="filterForm" class="row g-3 align-items-end">

                        <div class="col-xl-3 col-md-6">
                            <label class="form-label admin-label">CCCD</label>
                            <div class="input-wrap">
                                <i class="fa fa-id-card input-icon"></i>
                                <input id="cccdBox"
                                       class="form-control admin-input ps-5"
                                       placeholder="Nhập CCCD..." />
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <label class="form-label admin-label">Họ tên</label>
                            <div class="input-wrap">
                                <i class="fa fa-user input-icon"></i>
                                <input id="tenBox"
                                       class="form-control admin-input ps-5"
                                       placeholder="Nhập họ tên..." />
                            </div>
                        </div>

                        <div class="col-xl-2 col-md-4">
                            <label class="form-label admin-label">Hạng GPLX</label>
                            <select id="hangSelect" class="form-select admin-select">
                                <option value="">-- Tất cả --</option>
                                @if (ViewBag.Hangs != null)
                                {
                                    foreach (var h in ViewBag.Hangs)
                                    {
                                        <option value="@h.TENHANG">@h.TENHANG</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-xl-2 col-md-4">
                            <label class="form-label admin-label">Trạng thái</label>
                            <select id="statusSelect" class="form-select admin-select">
                                <option value="">-- Tất cả --</option>
                                <option value="Đang xử lý">Đang xử lý</option>
                                <option value="Đã duyệt">Đã duyệt</option>
                            </select>
                        </div>

                        <div class="col-xl-2 col-md-4">
                            <label class="form-label admin-label d-block opacity-0">Action</label>
                            <div class="d-flex gap-2">
                                <button type="button" id="btnSearch" class="btn btn-primary btn-admin-filter flex-fill">
                                    <i class="fa fa-search"></i>
                                </button>

                                <button type="button" id="btnReset" class="btn btn-light btn-admin-reset flex-fill">
                                    <i class="fa fa-rotate-left"></i>
                                </button>
                            </div>
                        </div>

                    </form>
                </div>

                <div id="hosoTable">
                    @await Html.PartialAsync("_HoSoTable", Model)
                </div>

            </div>
        </div>

    </div>
</section>

@section Styles {
    <style>
        .admin-hoso-page {
            font-family: "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
        }

        .hoso-hero {
            background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: 22px;
            padding: 24px 26px;
            box-shadow: 0 10px 30px rgba(15,23,42,0.05);
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(59,130,246,0.10);
            color: #2563eb;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .hero-title {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .hero-subtitle {
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
        }

        .hoso-card {
            background: #ffffff;
            border-radius: 22px;
            box-shadow: 0 12px 32px rgba(15,23,42,0.06);
            border: 1px solid rgba(15,23,42,0.06);
            overflow: hidden;
        }

        .filter-panel {
            background: linear-gradient(180deg, #fcfdff 0%, #f8fafc 100%);
            border: 1px solid rgba(148,163,184,0.18);
            border-radius: 18px;
            padding: 18px;
        }

        .admin-label {
            font-size: 14px;
            font-weight: 700;
            color: #334155;
            margin-bottom: 8px;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 14px;
            z-index: 2;
        }

        .admin-input,
        .admin-select {
            height: 48px;
            border-radius: 14px;
            border: 1px solid #dbe3ef;
            background: #fff;
            font-size: 14px;
            font-weight: 500;
            color: #0f172a;
            box-shadow: none;
            transition: all .2s ease;
        }

            .admin-input:focus,
            .admin-select:focus {
                border-color: rgba(37,99,235,0.45);
                box-shadow: 0 0 0 4px rgba(37,99,235,0.08);
            }

        .btn-admin-filter,
        .btn-admin-reset {
            height: 48px;
            border-radius: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all .2s ease;
        }

        .btn-admin-filter {
            box-shadow: 0 10px 20px rgba(37,99,235,0.18);
        }

        .btn-admin-reset {
            background: #f8fafc;
            border: 1px solid #dbe3ef;
            color: #334155;
        }

            .btn-admin-filter:hover,
            .btn-admin-reset:hover {
                transform: translateY(-1px);
            }

        @@media (max-width: 991.98px) {
            .hoso-hero {
                padding: 18px;
            }

            .hero-title {
                font-size: 24px;
            }

            .filter-panel {
                padding: 14px;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        function loadData() {
        $.ajax({
        url: '/AdminHoSo/Index',
        type: 'GET',
        data: {
        cccd: $("#cccdBox").val(),
        ten: $("#tenBox").val(),
        hang: $("#hangSelect").val(),
        trangthai: $("#statusSelect").val()
        },
        headers: { "X-Requested-With": "XMLHttpRequest" },
        success: function (res) {
        $("#hosoTable").html(res);
        }
        });
        }

        $("#cccdBox").on("keyup", function () {
        loadData();
        });

        $("#tenBox").on("keyup", function () {
        loadData();
        });

        $("#hangSelect, #statusSelect").on("change", function () {
        loadData();
        });

        $("#btnSearch").on("click", function () {
        loadData();
        });

        $("#btnReset").on("click", function () {
        $("#cccdBox").val("");
        $("#tenBox").val("");
        $("#hangSelect").val("");
        $("#statusSelect").val("");
        loadData();
        });
    </script>
}