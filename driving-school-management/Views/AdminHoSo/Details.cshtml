@model driving_school_management.ViewModels.HoSoDetailVM

@{
    ViewData["Title"] = "Chi tiết hồ sơ thí sinh";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var statusClass = Model.TrangThai == "Đã duyệt"
        ? "status-approved"
        : Model.TrangThai == "Từ chối"
            ? "status-rejected"
            : "status-processing";

    var avatarUrl = string.IsNullOrWhiteSpace(Model.AvatarUrl)
        ? "/images/avatar/default-avatar.png"
        : Model.AvatarUrl;
}

<section class="content">
    <div class="container-fluid admin-hoso-detail-page">

        <div class="detail-header-card mb-4">
            <div class="detail-title-wrap">
                <div class="detail-icon">
                    <i class="fa fa-file-text-o"></i>
                </div>
                <div>
                    <div class="detail-caption">Quản lý hồ sơ</div>
                    <h3 class="detail-page-title mb-1">Chi tiết hồ sơ thí sinh</h3>
                    <div class="detail-page-subtitle">Theo dõi thông tin học viên, hồ sơ đăng ký và phiếu khám sức khỏe.</div>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-xl-4 col-lg-6">
                <div class="detail-card h-100">
                    <div class="card-section-title section-info">
                        <i class="fa fa-user"></i>
                        <span>Thông tin học viên</span>
                    </div>

                    <div class="card-section-body">
                        <div class="student-profile">
                            <div class="student-avatar-wrap">
                                <img src="@avatarUrl"
                                     alt="Ảnh đại diện học viên"
                                     class="student-avatar"
                                     onclick="showImageModal('@avatarUrl')" />
                            </div>

                            <div class="student-avatar-caption">(Ảnh đại diện học viên)</div>

                            <div class="student-meta-list mt-4">
                                <div class="meta-row">
                                    <span>Họ tên</span>
                                    <strong>@Model.HoTen</strong>
                                </div>

                                <div class="meta-row">
                                    <span>Năm sinh</span>
                                    <strong>@(Model.NamSinh?.ToString("dd/MM/yyyy") ?? "")</strong>
                                </div>

                                <div class="meta-row">
                                    <span>Giới tính</span>
                                    <strong>@Model.GioiTinh</strong>
                                </div>

                                <div class="meta-row">
                                    <span>CCCD</span>
                                    <strong>@Model.CCCD</strong>
                                </div>

                                <div class="meta-row">
                                    <span>Số điện thoại</span>
                                    <strong>@Model.SDT</strong>
                                </div>

                                <div class="meta-row">
                                    <span>Email</span>
                                    <strong>@Model.Email</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-lg-6">
                <div class="detail-card h-100">
                    <div class="card-section-title section-primary">
                        <i class="fa fa-file-text"></i>
                        <span>Thông tin hồ sơ</span>
                    </div>

                    <div class="card-section-body">
                        <div class="info-list">
                            <div class="info-item">
                                <span>ID hồ sơ</span>
                                <strong>@Model.HoSoId</strong>
                            </div>

                            <div class="info-item">
                                <span>Tên hồ sơ</span>
                                <strong>@Model.TenHoSo</strong>
                            </div>

                            <div class="info-item">
                                <span>Loại hồ sơ</span>
                                <strong>@Model.LoaiHoSo</strong>
                            </div>

                            <div class="info-item">
                                <span>Ngày đăng ký</span>
                                <strong>@(Model.NgayDangKy?.ToString("dd/MM/yyyy") ?? "")</strong>
                            </div>

                            <div class="info-item">
                                <span>Hạng GPLX đăng ký</span>
                                <strong>@Model.TenHang</strong>
                            </div>

                            <div class="info-item">
                                <span>Trạng thái</span>
                                <strong>
                                    <span class="status-badge @statusClass">@Model.TrangThai</span>
                                </strong>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
                            {
                                <div class="info-item info-item-full">
                                    <span>Ghi chú</span>
                                    <strong>@Model.GhiChu</strong>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-lg-12">
                <div class="detail-card h-100">
                    <div class="card-section-title section-success">
                        <i class="fa fa-heartbeat"></i>
                        <span>Phiếu khám sức khỏe</span>
                    </div>

                    <div class="card-section-body">
                        <div class="info-list">
                            <div class="info-item">
                                <span>Hiệu lực</span>
                                <strong>@Model.HieuLuc</strong>
                            </div>

                            <div class="info-item">
                                <span>Thời hạn</span>
                                <strong>@(Model.ThoiHan?.ToString("dd/MM/yyyy") ?? "")</strong>
                            </div>

                            <div class="info-item">
                                <span>Khám mắt</span>
                                <strong>@Model.KhamMat</strong>
                            </div>

                            <div class="info-item">
                                <span>Huyết áp</span>
                                <strong>@Model.HuyetAp</strong>
                            </div>

                            <div class="info-item">
                                <span>Chiều cao</span>
                                <strong>@(Model.ChieuCao?.ToString("0.##") ?? "") m</strong>
                            </div>

                            <div class="info-item">
                                <span>Cân nặng</span>
                                <strong>@(Model.CanNang?.ToString("0.##") ?? "") kg</strong>
                            </div>
                        </div>

                        <div class="proof-block">
                            <div class="proof-title">
                                <i class="fa fa-image"></i>
                                <span>Ảnh minh chứng</span>
                            </div>

                            @if (Model.AnhMinhChungs != null && Model.AnhMinhChungs.Any())
                            {
                                <div class="proof-gallery mt-3">
                                    @foreach (var img in Model.AnhMinhChungs)
                                    {
                                        if (!string.IsNullOrWhiteSpace(img.UrlAnh))
                                        {
                                            <div class="proof-thumb-card">
                                                <img src="@img.UrlAnh"
                                                     alt="Ảnh minh chứng"
                                                     class="proof-thumb"
                                                     onclick="showImageModal('@img.UrlAnh')" />
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="proof-empty mt-3">Không có ảnh giấy khám sức khỏe.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="action-bar mt-4">
            <a asp-controller="AdminHoSo"
                   asp-action="Index"
                   class="btn btn-back-action">
                <i class="fa fa-arrow-left"></i>
                <span>Quay lại</span>
            </a>

            <div class="action-right-group">
                @if (Model.TrangThai != "Đã duyệt")
                {
                    <button type="button"
                            class="btn btn-approve-action"
                            onclick="approveHoSo(@Model.HoSoId)">
                        <i class="fa fa-check"></i>
                        <span>Duyệt</span>
                    </button>
                }

                @if (Model.TrangThai != "Từ chối")
                {
                    <button type="button"
                            class="btn btn-reject-action"
                            onclick="rejectHoSo(@Model.HoSoId)">
                        <i class="fa fa-times"></i>
                        <span>Từ chối</span>
                    </button>
                }
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content image-modal-content">
            <button type="button" class="image-modal-close" data-bs-dismiss="modal" aria-label="Close">
                <i class="fa fa-times"></i>
            </button>
            <div class="image-modal-body">
                <img id="previewImage" src="" alt="Preview" class="preview-image" />
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-hoso-detail-page {
            font-family: "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
        }

        .detail-header-card {
            border-radius: 24px;
            padding: 22px 26px;
            background: linear-gradient(135deg, #2563eb, #4f7df3);
            box-shadow: 0 16px 36px rgba(37,99,235,0.20);
            position: relative;
            overflow: hidden;
        }

            .detail-header-card::after {
                content: "";
                position: absolute;
                width: 220px;
                height: 220px;
                right: -60px;
                top: -80px;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
            }

        .detail-title-wrap {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
            z-index: 1;
        }

        .detail-icon {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: rgba(255,255,255,0.16);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
        }

        .detail-caption {
            font-size: 13px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: rgba(255,255,255,0.82);
            margin-bottom: 4px;
        }

        .detail-page-title {
            font-size: 34px;
            font-weight: 800;
            color: #fff;
            margin: 0;
        }

        .detail-page-subtitle {
            color: rgba(255,255,255,0.86);
            font-size: 14px;
            font-weight: 500;
        }

        .detail-card {
            background: rgba(255,255,255,0.94);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: 24px;
            box-shadow: 0 14px 34px rgba(15,23,42,0.06);
            overflow: hidden;
            height: 100%;
        }

        .card-section-title {
            padding: 18px 22px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #fff;
            font-size: 24px;
            font-weight: 800;
            line-height: 1;
        }

        .section-info {
            background: linear-gradient(135deg, #0891b2, #4fb4d0);
        }

        .section-primary {
            background: linear-gradient(135deg, #2563eb, #4f7df3);
        }

        .section-success {
            background: linear-gradient(135deg, #16a34a, #5cbc59);
        }

        .card-section-body {
            padding: 24px 20px 22px;
        }

        .student-profile {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .student-avatar-wrap {
            display: flex;
            justify-content: center;
        }

        .student-avatar {
            width: 142px;
            height: 142px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #e0f2fe;
            box-shadow: 0 14px 28px rgba(14,165,233,0.16);
            cursor: pointer;
            transition: transform .2s ease;
        }

            .student-avatar:hover {
                transform: scale(1.02);
            }

        .student-avatar-caption {
            margin-top: 12px;
            font-size: 13px;
            color: #64748b;
        }

        .student-meta-list,
        .info-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            width: 100%;
        }

        .meta-row,
        .info-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            padding: 11px 14px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
        }

            .meta-row span,
            .info-item span {
                color: #475569;
                font-size: 14px;
                font-weight: 700;
                min-width: 120px;
            }

            .meta-row strong,
            .info-item strong {
                color: #0f172a;
                font-size: 15px;
                font-weight: 800;
                text-align: right;
                flex: 1;
                word-break: break-word;
            }

        .info-item-full {
            align-items: flex-start;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 7px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .status-processing {
            background: rgba(6,182,212,0.14);
            color: #0891b2;
        }

        .status-approved {
            background: rgba(34,197,94,0.14);
            color: #15803d;
        }

        .status-rejected {
            background: rgba(239,68,68,0.14);
            color: #dc2626;
        }

        .proof-block {
            margin-top: 22px;
            padding-top: 18px;
            border-top: 1px dashed #dbe3ef;
        }

        .proof-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #0f172a;
            font-size: 18px;
            font-weight: 800;
        }

        .proof-gallery {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .proof-thumb-card {
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid #dbeafe;
            background: #f8fafc;
            box-shadow: 0 8px 18px rgba(15,23,42,0.04);
        }

        .proof-thumb {
            width: 100%;
            height: 170px;
            object-fit: cover;
            display: block;
            cursor: pointer;
            transition: transform .25s ease;
        }

            .proof-thumb:hover {
                transform: scale(1.03);
            }

        .proof-empty {
            color: #64748b;
            font-size: 14px;
            font-style: italic;
        }

        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
        }

        .action-right-group {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-back-action,
        .btn-approve-action,
        .btn-reject-action {
            min-width: 132px;
            height: 48px;
            padding: 0 18px;
            border-radius: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: none;
            text-decoration: none;
            transition: all .2s ease;
            box-shadow: 0 10px 22px rgba(15,23,42,0.08);
        }

        .btn-back-action {
            background: #64748b;
            color: #fff;
        }

        .btn-approve-action {
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
        }

        .btn-reject-action {
            background: linear-gradient(135deg, #dc2626, #ef4444);
            color: #fff;
        }

            .btn-back-action:hover,
            .btn-approve-action:hover,
            .btn-reject-action:hover {
                transform: translateY(-1px);
                color: #fff;
                filter: brightness(1.02);
            }

        .image-modal-content {
            background: #0f172a;
            border: none;
            border-radius: 22px;
            overflow: hidden;
            position: relative;
        }

        .image-modal-body {
            padding: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 70vh;
        }

        .preview-image {
            max-width: 100%;
            max-height: 76vh;
            object-fit: contain;
            border-radius: 16px;
            background: #fff;
        }

        .image-modal-close {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 50%;
            background: rgba(255,255,255,0.14);
            color: #fff;
            z-index: 5;
        }

        .swal2-popup {
            border-radius: 22px !important;
            padding: 1.6rem !important;
        }

        .swal2-title {
            font-weight: 800 !important;
        }

        .swal2-confirm,
        .swal2-cancel {
            border-radius: 12px !important;
            padding: 10px 18px !important;
            font-weight: 700 !important;
        }

        @@media (max-width: 1199.98px) {
            .detail-page-title {
                font-size: 28px;
            }
        }

        @@media (max-width: 991.98px) {
            .detail-header-card {
                padding: 18px;
            }

            .detail-page-title {
                font-size: 24px;
            }

            .card-section-title {
                font-size: 20px;
            }
        }

        @@media (max-width: 575.98px) {
            .proof-gallery {
                grid-template-columns: 1fr;
            }

            .meta-row,
            .info-item {
                flex-direction: column;
                gap: 6px;
            }

                .meta-row strong,
                .info-item strong {
                    text-align: left;
                }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function approveHoSo(id) {
        Swal.fire({
        title: 'Xác nhận duyệt hồ sơ?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#16a34a',
        cancelButtonColor: '#64748b',
        confirmButtonText: '<i class="fa fa-check"></i> Duyệt',
        cancelButtonText: 'Hủy',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = '/AdminHoSo/Approve/' + id;
        }
        });
        }

        function rejectHoSo(id) {
        Swal.fire({
        title: 'Xác nhận từ chối hồ sơ?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc2626',
        cancelButtonColor: '#64748b',
        confirmButtonText: '<i class="fa fa-times"></i> Từ chối',
        cancelButtonText: 'Hủy',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = '/AdminHoSo/Reject/' + id;
        }
        });
        }

        function showImageModal(url) {
        if (!url || url === 'null') return;

        const img = document.getElementById('previewImage');
        img.src = url;

        const modalEl = document.getElementById('imagePreviewModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
        }
    </script>
}