@{
    ViewData["Title"] = "Thanh toán thất bại";
    var message = ViewBag.Message ?? "Đã xảy ra lỗi trong quá trình thanh toán.";
}

<style>
    body {
        background: #f5f6f8;
        font-family: 'Segoe UI', sans-serif;
    }

    .wrapper {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        width: 420px;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        animation: fadeUp 0.5s ease;
    }

    .icon {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: #fef2f2;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        margin-bottom: 20px;
        font-size: 28px;
        color: #dc2626;
    }

    .title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 10px;
    }

    .desc {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 25px;
    }

    .btn-group {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    .btn-primary {
        padding: 12px 18px;
        border-radius: 12px;
        border: none;
        background: #111827;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-secondary {
        padding: 12px 18px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-primary:hover {
        background: #020617;
    }

    .btn-secondary:hover {
        background: #eef2f7;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="wrapper">
    <div class="card">
        <div class="icon">✖</div>
        <div class="title">Thanh toán thất bại</div>
        <div class="desc">@message</div>

        <div class="btn-group">
            <a href="/KhoaHoc" class="btn-secondary">Quay lại</a>
            <button onclick="history.back()" class="btn-primary">Thử lại</button>
        </div>
    </div>
</div>